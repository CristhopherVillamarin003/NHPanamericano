---------------------SEGURIDADES-------------------------

CREATE TABLE seguridad.usuario (
  id SERIAL PRIMARY KEY,
  email TEXT UNIQUE NOT NULL,
  password TEXT NOT NULL,
  nombres TEXT,
  apellidos TEXT,
  activo BOOLEAN DEFAULT TRUE,
  email_verificado BOOLEAN DEFAULT FALSE,
  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE seguridad.rol (
  id SERIAL PRIMARY KEY,
  nombre TEXT UNIQUE NOT NULL,
  descripcion TEXT
);

CREATE TABLE seguridad.permiso (
  id SERIAL PRIMARY KEY,
  codigo TEXT UNIQUE NOT NULL,
  descripcion TEXT
);

CREATE TABLE seguridad.usuario_rol (
  usuario_id INT NOT NULL,
  rol_id INT NOT NULL,

  PRIMARY KEY (usuario_id, rol_id),

  CONSTRAINT fk_usuario
    FOREIGN KEY (usuario_id)
    REFERENCES seguridad.usuario(id)
    ON DELETE CASCADE,

  CONSTRAINT fk_rol
    FOREIGN KEY (rol_id)
    REFERENCES seguridad.rol(id)
    ON DELETE CASCADE
);

CREATE TABLE seguridad.rol_permiso (
  rol_id INT NOT NULL,
  permiso_id INT NOT NULL,

  PRIMARY KEY (rol_id, permiso_id),

  CONSTRAINT fk_rol_permiso_rol
    FOREIGN KEY (rol_id)
    REFERENCES seguridad.rol(id)
    ON DELETE CASCADE,

  CONSTRAINT fk_rol_permiso_permiso
    FOREIGN KEY (permiso_id)
    REFERENCES seguridad.permiso(id)
    ON DELETE CASCADE
);

CREATE TABLE seguridad.refresh_token (
  id SERIAL PRIMARY KEY,
  usuario_id INT NOT NULL,
  token TEXT NOT NULL,
  expiracion TIMESTAMP NOT NULL,
  creado_en TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

  CONSTRAINT fk_refresh_usuario
    FOREIGN KEY (usuario_id)
    REFERENCES seguridad.usuario(id)
    ON DELETE CASCADE
);

CREATE TABLE seguridad.recuperacion_password (
  id SERIAL PRIMARY KEY,
  usuario_id INT NOT NULL,
  token TEXT NOT NULL,
  expiracion TIMESTAMP NOT NULL,
  usado BOOLEAN DEFAULT FALSE,
  creado_en TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

  CONSTRAINT fk_recuperacion_usuario
    FOREIGN KEY (usuario_id)
    REFERENCES seguridad.usuario(id)
    ON DELETE CASCADE
);

---------------------HOSPITAL-------------------------

CREATE TABLE hospital.categoria (
  id SERIAL PRIMARY KEY,
  nombre TEXT NOT NULL,
  descripcion TEXT,
  usuario_id INT NOT NULL,
  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

  CONSTRAINT fk_categoria_usuario
    FOREIGN KEY (usuario_id)
    REFERENCES seguridad.usuario(id)
    ON DELETE CASCADE
);

CREATE TABLE hospital.paciente (
  id SERIAL PRIMARY KEY,

  primer_nombre TEXT NOT NULL,
  segundo_nombre TEXT,
  primer_apellido TEXT NOT NULL,
  segundo_apellido TEXT,

  cedula TEXT UNIQUE,
  fecha_nacimiento DATE,
  edad INT,

  tipo_paciente TEXT,

  sexo TEXT,
  telefono TEXT,
  direccion TEXT,

  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE hospital.categoria_paciente (
  id SERIAL PRIMARY KEY,

  categoria_id INT NOT NULL,
  paciente_id INT NOT NULL,

  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

  CONSTRAINT fk_categoria_paciente_categoria
    FOREIGN KEY (categoria_id)
    REFERENCES hospital.categoria(id)
    ON DELETE CASCADE,

  CONSTRAINT fk_categoria_paciente_paciente
    FOREIGN KEY (paciente_id)
    REFERENCES hospital.paciente(id)
    ON DELETE CASCADE,

  CONSTRAINT unique_categoria_paciente
    UNIQUE (categoria_id, paciente_id)
);

------------LÓGICA INFORMACIÓN DE PACIENTES-------------------------

CREATE TABLE hospital.atencion (
  id SERIAL PRIMARY KEY,
  categoria_paciente_id INT NOT NULL UNIQUE,
  estado TEXT DEFAULT 'activo',
  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

  CONSTRAINT fk_atencion_cat_pac
    FOREIGN KEY (categoria_paciente_id)
    REFERENCES hospital.categoria_paciente(id)
    ON DELETE CASCADE
);

-- Catálogo de plantillas MSP
CREATE TABLE hospital.plantilla (
  id SERIAL PRIMARY KEY,
  codigo TEXT,
  nombre TEXT NOT NULL,
  seccion TEXT NOT NULL,
  tipo_archivo TEXT NOT NULL,  -- 'xlsx' | 'docx'
  es_plantilla_fija BOOLEAN DEFAULT TRUE, -- FALSE para cuidado y receta
  ruta_archivo TEXT,           -- NULL si no tiene plantilla fija
  activo BOOLEAN DEFAULT TRUE
);

CREATE TABLE hospital.consentimiento (
  id SERIAL PRIMARY KEY,
  atencion_id INT NOT NULL,
  plantilla_id INT NOT NULL,
  datos JSONB NOT NULL DEFAULT '{}',
  estado TEXT DEFAULT 'borrador', -- 'borrador' | 'firmado' | 'anulado'
  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

  CONSTRAINT fk_cons_atencion   FOREIGN KEY (atencion_id)  REFERENCES hospital.atencion(id)  ON DELETE CASCADE,
  CONSTRAINT fk_cons_plantilla  FOREIGN KEY (plantilla_id) REFERENCES hospital.plantilla(id)
);

CREATE TABLE hospital.historia_clinica (
  id SERIAL PRIMARY KEY,
  atencion_id INT NOT NULL UNIQUE,
  plantilla_id INT NOT NULL,
  datos JSONB NOT NULL DEFAULT '{}',
  estado TEXT DEFAULT 'borrador',
  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

  CONSTRAINT fk_hc_atencion   FOREIGN KEY (atencion_id)  REFERENCES hospital.atencion(id)  ON DELETE CASCADE,
  CONSTRAINT fk_hc_plantilla  FOREIGN KEY (plantilla_id) REFERENCES hospital.plantilla(id)
);

CREATE TABLE hospital.protocolo (
  id SERIAL PRIMARY KEY,
  atencion_id INT NOT NULL UNIQUE,
  plantilla_id INT NOT NULL,
  datos JSONB NOT NULL DEFAULT '{}',
  estado TEXT DEFAULT 'borrador',
  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  CONSTRAINT fk_protocolo_atencion FOREIGN KEY (atencion_id) REFERENCES hospital.atencion(id) ON DELETE CASCADE,
  CONSTRAINT fk_protocolo_plantilla FOREIGN KEY (plantilla_id) REFERENCES hospital.plantilla(id)
);

CREATE TABLE hospital.cuidado (
  id SERIAL PRIMARY KEY,
  atencion_id INT NOT NULL UNIQUE,
  plantilla_id INT NOT NULL,
  datos JSONB NOT NULL DEFAULT '{}',
  estado TEXT DEFAULT 'borrador',
  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  CONSTRAINT fk_cuidado_atencion FOREIGN KEY (atencion_id) REFERENCES hospital.atencion(id) ON DELETE CASCADE,
  CONSTRAINT fk_cuidado_plantilla FOREIGN KEY (plantilla_id) REFERENCES hospital.plantilla(id)
);

CREATE TABLE hospital.epicrisis (
  id SERIAL PRIMARY KEY,
  atencion_id INT NOT NULL UNIQUE,
  plantilla_id INT NOT NULL,
  datos JSONB NOT NULL DEFAULT '{}',
  estado TEXT DEFAULT 'borrador',
  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  CONSTRAINT fk_epicrisis_atencion FOREIGN KEY (atencion_id) REFERENCES hospital.atencion(id) ON DELETE CASCADE,
  CONSTRAINT fk_epicrisis_plantilla FOREIGN KEY (plantilla_id) REFERENCES hospital.plantilla(id)
);

CREATE TABLE hospital.receta (
  id SERIAL PRIMARY KEY,
  atencion_id INT NOT NULL UNIQUE,
  plantilla_id INT NOT NULL,
  datos JSONB NOT NULL DEFAULT '{}',
  estado TEXT DEFAULT 'borrador',
  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  CONSTRAINT fk_receta_atencion FOREIGN KEY (atencion_id) REFERENCES hospital.atencion(id) ON DELETE CASCADE,
  CONSTRAINT fk_receta_plantilla FOREIGN KEY (plantilla_id) REFERENCES hospital.plantilla(id)
);

CREATE TABLE IF NOT EXISTS hospital.cie10
(
    id integer NOT NULL GENERATED ALWAYS AS IDENTITY,
    codigo varchar(10) COLLATE pg_catalog."default" NOT NULL,
    descripcion text COLLATE pg_catalog."default" NOT NULL,
    created_at timestamp without time zone DEFAULT CURRENT_TIMESTAMP,

    CONSTRAINT cie10_pkey PRIMARY KEY (id),
    CONSTRAINT cie10_codigo_key UNIQUE (codigo)
)

TABLESPACE pg_default;